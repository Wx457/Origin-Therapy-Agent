# Cedar Kids Therapy triage agent - environment variable template.
#
# How to use:
#   1) Copy this file to `.env` in the same directory.
#   2) Replace the placeholder below with the real API key Origin issued.
#   3) `.env` is already in .gitignore, so it will not be committed.
#
# Note: this is only for the synthetic data shipped with the starter pack.
# Do not use a real API key with real PHI.

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_REAL_KEY

# Optional: override the default model. Leave blank to use the Sonnet 4.5
# pinned in src/llm.ts.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
